{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Package",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${fileDirname}"
        },
        {
            "name": "embedded-demo (asia)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/distributed-counter-crdt/embedded-demo",
            "env": {
                "NODE_ID": "asia",
                "COLOR": "#f97316"
            }
        },
        {
            "name": "code-demo: asia",
